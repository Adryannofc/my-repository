<canvas id="ascii-bg" aria-hidden="true"></canvas>

<script>
  function init() {
    const canvas = document.getElementById('ascii-bg') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d') as CanvasRenderingContext2D;
    if (!ctx) return;

    const CELL = 14;
    const HALF = CELL / 2;
    const CHARS = ' ·.:+*#@';
    const CHAR_MAX = CHARS.length - 1;

    let w = 0, h = 0, cols = 0, rows = 0, raf = 0;
    const t0 = performance.now();

    function setupCtx() {
      ctx.fillStyle = 'rgb(242,135,5)';
      ctx.font = `${CELL}px "JetBrains Mono", monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
    }

    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      const pw = parent.offsetWidth;
      const ph = parent.offsetHeight;
      if (pw === w && ph === h) return; // skip GPU realloc when nothing changed
      w = pw; h = ph;
      canvas.width = w;
      canvas.height = h;
      cols = Math.ceil(w / CELL) + 1;
      rows = Math.ceil(h / CELL) + 1;
      setupCtx();
    }

    function sample(cx: number, cy: number, t: number): number {
      const a = Math.sin(cx * 0.08 + t * 0.40) * Math.cos(cy * 0.07 + t * 0.25);
      const b = Math.sin(cx * 0.05 + cy * 0.06 + t * 0.60);
      const c = Math.cos(cx * 0.12 - cy * 0.08 + t * 0.35);
      return (a * 0.5 + b * 0.3 + c * 0.2 + 1) / 2;
    }

    function draw() {
      const t = (performance.now() - t0) / 1000;
      ctx.clearRect(0, 0, w, h);
      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const brightness = sample(col, row, t);
          const idx = Math.floor(brightness * CHAR_MAX);
          const ch = CHARS[idx];
          if (ch === ' ') continue;
          ctx.globalAlpha = brightness * 0.18; // no string alloc — avoids ~3500 rgba() strings/frame
          ctx.fillText(ch, col * CELL + HALF, row * CELL + HALF);
        }
      }
      raf = requestAnimationFrame(draw);
    }

    resize();

    const ro = new ResizeObserver(resize);
    if (canvas.parentElement) ro.observe(canvas.parentElement);

    let io: IntersectionObserver | undefined;
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Pause RAF when hero is scrolled out of view
      io = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) { if (!raf) raf = requestAnimationFrame(draw); }
          else { cancelAnimationFrame(raf); raf = 0; }
        },
        { threshold: 0.05 }
      );
      io.observe(canvas);
    }

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      ro.disconnect();
      io?.disconnect();
    }, { once: true });
  }

  init();
</script>

<style>
  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>
