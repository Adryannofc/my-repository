---
import { useTranslations } from '../i18n/utils';
import { projects } from '../data/projects';

interface Props {
  lang: 'en' | 'pt-br';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="projects" aria-labelledby="projects-heading">
  <div class="projects-container">

    <p class="projects-overline">{t.projects.overline}</p>

    <h2 id="projects-heading" class="projects-heading">{t.projects.heading}</h2>

    <ul class="projects-grid" role="list" data-projects>
      {projects.map((p) => (
        <li class="project-card" role="listitem" style={`--index: ${p.id - 1}`}>
          <div class="card-top">
            <span class="card-number" aria-hidden="true">
              {String(p.id).padStart(2, '0')}
            </span>
            <h3 class="card-name">{p.name}</h3>
            <p class="card-desc">
              {lang === 'en' ? p.descriptionEn : p.descriptionPtBr}
            </p>
          </div>
          <div class="card-bottom">
            <ul class="badge-row" role="list" aria-label="Technologies">
              {p.technologies.map((tech) => (
                <li class="badge" role="listitem">{tech}</li>
              ))}
            </ul>
            <div class="card-links">
              <a
                href={p.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${p.name} — ${t.projects.github_label}`}
                class="card-link"
              >
                {t.projects.github_label}
              </a>
              {p.liveUrl && (
                <a
                  href={p.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${p.name} — ${t.projects.live_label}`}
                  class="card-link"
                >
                  {t.projects.live_label}
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<script>
  (function () {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const grid = document.querySelector('[data-projects]');
    if (!grid || reduced) return;

    const cards = grid.querySelectorAll<HTMLElement>('.project-card');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.unobserve(entry.target);
            cards.forEach((card) => {
              card.classList.add('visible');
            });
          }
        });
      },
      { threshold: 0.1 }
    );

    observer.observe(grid);
  })();
</script>

<style>
  section {
    width: 100%;
    background-color: var(--bg-base);
  }

  .projects-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 96px 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .projects-overline {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0;
  }

  .projects-heading {
    font-family: var(--font-sans);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--text-primary);
    margin: 0;
  }

  /* Grid */
  .projects-grid {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Card */
  .project-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-neutral);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 16px;
    min-height: 140px;

    /* Scroll-triggered animation initial state */
    opacity: 0;
    transform: translateY(16px);
  }

  .project-card.visible {
    animation: fade-in-up 600ms ease forwards;
    animation-delay: calc(var(--index) * 80ms);
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card {
      transition:
        border-color 250ms ease,
        transform 250ms ease,
        box-shadow 250ms ease;
    }

    .project-card:hover {
      border-color: var(--border-accent);
      transform: translateY(-4px);
      box-shadow: 0 8px 32px rgba(242, 135, 5, 0.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      opacity: 1;
      transform: none;
    }

    .project-card.visible {
      animation: none;
    }
  }

  /* Card top */
  .card-top {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-number {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 400;
    color: var(--accent);
    line-height: 1;
  }

  .card-name {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .card-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Card bottom */
  .card-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .badge-row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
    border-radius: 9999px;
    padding: 4px 10px;
    white-space: nowrap;
    line-height: 1;
  }

  .card-links {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .card-link {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--text-ghost);
    text-decoration: none;
    line-height: 1;
    transition: color 150ms ease;
  }

  .card-link:hover {
    color: var(--text-secondary);
  }

  .card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-link {
      transition: none;
    }
  }

  @media (max-width: 767px) {
    .projects-container {
      padding: 64px 24px;
    }
  }
</style>
