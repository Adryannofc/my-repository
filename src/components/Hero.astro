---
import { useTranslations } from '../i18n/utils';
import { socialLinks } from '../data/social';
import Ticker from './Ticker.astro';
import AsciiTerminal from './AsciiTerminal.astro';
import { Github, Linkedin, MessageCircle } from 'lucide-astro';

interface Props {
  lang: 'en' | 'pt-br';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const iconMap = { Github, Linkedin, MessageCircle } as const;
---

<section aria-labelledby="hero-heading">
  <div class="hero-container">

    <div class="hero-left">
      <p class="hero-overline">{t.hero.overline}</p>

      <h1 id="hero-heading" class="hero-h1">
        <span class="hero-line" data-hero-line="0">{t.hero.heading_line1}</span>
        <span class="hero-line" data-hero-line="1">{t.hero.heading_line2}</span>
        <span class="hero-line" data-hero-line="2">{t.hero.heading_line3}</span>
      </h1>

      <p class="hero-subtext">{t.hero.subtext}</p>

      <div class="hero-social" role="list">
        {socialLinks.map((link) => {
          const label = lang === 'en' ? link.labelEn : link.labelPtBr;
          const Icon = iconMap[link.icon];
          return (
            <a
              href={link.href}
              class="hero-social-link"
              aria-label={label}
              target="_blank"
              rel="noopener noreferrer"
              role="listitem"
            >
              {Icon && <Icon size={24} strokeWidth={1.5} aria-hidden="true" />}
            </a>
          );
        })}
      </div>
    </div>

    <div class="hero-right" aria-hidden="true">
      <AsciiTerminal />
    </div>

  </div>
</section>

<Ticker items={t.hero.ticker} />

<script>
  (function () {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    const lines = document.querySelectorAll<HTMLElement>('.hero-line');

    function revealLines() {
      [0, 80, 160].forEach((delay, i) =>
        setTimeout(() => lines[i]?.classList.add('visible'), delay)
      );
    }

    if (!document.body.classList.contains('booting')) {
      revealLines();
      return;
    }

    const observer = new MutationObserver(() => {
      if (!document.body.classList.contains('booting')) {
        observer.disconnect();
        revealLines();
      }
    });

    observer.observe(document.body, {
      attributes: true,
      attributeFilter: ['class'],
    });
  })();
</script>

<style>
  section {
    width: 100%;
    min-height: 100vh;
    background-color: var(--bg-base);
    display: flex;
    flex-direction: column;
  }

  .hero-container {
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 96px 24px 64px;
    flex: 1;
    display: flex;
    align-items: center;
    gap: 48px;
  }

  /* ── Left block ───────────────────────────────── */

  .hero-left {
    flex: 0 0 60%;
    max-width: 60%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero-overline {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0;
  }

  .hero-h1 {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .hero-line {
    display: block;
    font-family: var(--font-sans);
    font-size: clamp(48px, 9vw, 96px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--text-primary);
    opacity: 0;
  }

  .hero-line.visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-line {
      transition: opacity 600ms ease, transform 600ms ease;
      transform: translateY(16px);
    }

    .hero-line.visible {
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-line {
      opacity: 1;
      transform: none;
    }
  }

  .hero-subtext {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--text-muted);
    margin: 0;
    max-width: 480px;
  }

  /* ── Social row ───────────────────────────────── */

  .hero-social {
    display: flex;
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-social-link {
    display: flex;
    align-items: center;
    color: var(--text-ghost);
    text-decoration: none;
  }

  .hero-social-link:hover {
    color: var(--text-primary);
  }

  .hero-social-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-social-link {
      transition: color 150ms ease;
    }
  }

  /* ── Right block ──────────────────────────────── */

  .hero-right {
    flex: 0 0 40%;
    max-width: 40%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 8px;
  }

  /* ── Responsive ───────────────────────────────── */

  @media (max-width: 767px) {
    .hero-container {
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 32px;
      padding-top: 64px;
      padding-bottom: 48px;
    }

    .hero-left {
      flex: none;
      max-width: 100%;
      width: 100%;
    }

    .hero-right {
      display: none;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-left {
      flex: 0 0 65%;
      max-width: 65%;
    }

    .hero-right {
      flex: 0 0 35%;
      max-width: 35%;
    }
  }
</style>
