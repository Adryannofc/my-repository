---
import '../styles/global.css';
import Boot from '../components/Boot.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'pt-br';
  canonicalUrl?: string;
}

const {
  title,
  description = 'Software Engineer portfolio',
  lang = 'en',
  canonicalUrl,
} = Astro.props;

const hreflangEn   = new URL('/en/',    Astro.site ?? 'http://localhost:4321').href;
const hreflangPtBr = new URL('/pt-br/', Astro.site ?? 'http://localhost:4321').href;
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="en"    href={hreflangEn} />
    <link rel="alternate" hreflang="pt-BR" href={hreflangPtBr} />
    <link rel="alternate" hreflang="x-default" href={hreflangEn} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

    <title>{title}</title>

    <!-- Boot: hide content until boot sequence completes (LCP preserved via visibility:hidden) -->
    <style>
      body.booting > header,
      body.booting > main,
      body.booting > footer {
        visibility: hidden;
      }

      /* prefers-reduced-motion: skip boot entirely, show content immediately */
      @media (prefers-reduced-motion: reduce) {
        #boot-screen { display: none !important; }
        body.booting > header,
        body.booting > main,
        body.booting > footer { visibility: visible !important; }
      }
    </style>
  </head>

  <body class="booting">
    <Boot lang={lang} />

    <!-- Skip to content — accessibility (z-index 9999, above boot overlay) -->
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <header role="banner">
      <slot name="header" />
    </header>

    <main id="main-content" role="main" tabindex="-1">
      <slot />
    </main>

    <footer role="contentinfo">
      <slot name="footer" />
    </footer>
  </body>
</html>
