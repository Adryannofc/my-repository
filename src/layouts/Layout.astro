---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'pt-br';
  canonicalUrl?: string;
}

const {
  title,
  description = 'Software Engineer portfolio',
  lang = 'en',
  canonicalUrl,
} = Astro.props;

const hreflangEn   = new URL('/en/',    Astro.site ?? 'http://localhost:4321').href;
const hreflangPtBr = new URL('/pt-br/', Astro.site ?? 'http://localhost:4321').href;
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="en"    href={hreflangEn} />
    <link rel="alternate" hreflang="pt-BR" href={hreflangPtBr} />
    <link rel="alternate" hreflang="x-default" href={hreflangEn} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

    <title>{title}</title>
  </head>

  <body>
    <!-- Skip to content — accessibility -->
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <header role="banner">
      <slot name="header" />
    </header>

    <main id="main-content" role="main" tabindex="-1">
      <slot />
    </main>

    <footer role="contentinfo">
      <slot name="footer" />
    </footer>
  </body>
</html>
